@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_SecureLayout";
}

<h4>Dashboard</h4>
<p class="grey-text">@Model.WelcomeMessage</p>

<div class="row">
    <div class="col s12 m6 xl3">
        <div class="card asc-stat-card">
            <div class="card-content">
                <span class="card-title">Service Requests</span>
                <h3>@Model.TotalServiceRequests</h3>
            </div>
        </div>
    </div>
    <div class="col s12 m6 xl3">
        <div class="card asc-stat-card">
            <div class="card-content">
                <span class="card-title">Open Requests</span>
                <h3>@Model.OpenServiceRequests</h3>
            </div>
        </div>
    </div>
    <div class="col s12 m6 xl3">
        <div class="card asc-stat-card">
            <div class="card-content">
                <span class="card-title">Products</span>
                <h3>@Model.TotalProducts</h3>
            </div>
        </div>
    </div>
    <div class="col s12 m6 xl3">
        <div class="card asc-stat-card">
            <div class="card-content">
                <span class="card-title">Master Data Values</span>
                <h3>@Model.TotalMasterDataValues</h3>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-content">
        <span class="card-title">Recent service requests</span>
        <table class="highlight responsive-table">
            <thead>
                <tr>
                    <th>Request</th>
                    <th>Customer</th>
                    <th>Service</th>
                    <th>Status</th>
                    <th>Appointment (UTC)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model.RecentRequests)
                {
                    <tr>
                        <td>@request.RequestNumber</td>
                        <td>@request.CustomerName</td>
                        <td>@request.ServiceType</td>
                        <td><span class="new badge asc-status-badge" data-badge-caption="">@request.Status</span></td>
                        <td>@request.AppointmentDateUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card blue-grey lighten-5">
    <div class="card-content">
        <span class="card-title">Seeded identity accounts</span>
        <p><strong>Admin:</strong> admin@asc.local / Admin@12345</p>
        <p><strong>Engineer:</strong> engineer1@asc.local / Engineer@12345</p>
        <p><strong>Customer:</strong> customer1@asc.local / Customer@12345</p>
        <p><strong>Support:</strong> @Model.SupportEmail</p>
    </div>
</div>
